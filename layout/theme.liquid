<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, height=device-height, minimum-scale=1.0">
    <meta name="theme-color" content="#6B5FD4">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {%- if template == 'index' -%}
        {{ shop.name }} — {{ shop.description | default: page_title }}
      {%- elsif page_title == shop.name -%}
        {{ page_title }}
      {%- else -%}
        {{ page_title }} — {{ shop.name }}
      {%- endif -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {{ content_for_header }}

    {{ 'kyndcubs-global.css' | asset_url | stylesheet_tag }}

    <style>
      *, *::before, *::after { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: 'Nunito', sans-serif;
        background-color: var(--kc-page-bg, #FBF8F4);
        color: var(--kc-ink, #2C2A3A);
        -webkit-font-smoothing: antialiased;
      }
      img, video { max-width: 100%; height: auto; }
      a { color: inherit; text-decoration: none; }
    </style>
  </head>

  <body class="template-{{ template.name | handle }}{% if customer %} customer-logged-in{% endif %}">
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      {{ 'accessibility.skip_to_text' | t | default: 'Skip to content' }}
    </a>

    {%- sections 'header-group' -%}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {%- sections 'footer-group' -%}

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
    </script>
  </body>
</html>
