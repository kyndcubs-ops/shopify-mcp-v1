<div id="kc-reviews" class="kc-reviews-section shopify-section">
  <div class="kc-rev__inner">
    <p class="kc-rev__label">{{ section.settings.reviews_label }}</p>
    <div class="kc-rev__summary">
      <div class="kc-rev__score-wrap">
        <span class="kc-rev__big-score" id="kcRevScore-{{ section.id }}">4.8</span>
        <div class="kc-rev__stars-row">
          <span class="kc-rev__stars">★★★★★</span>
          <span class="kc-rev__meta" id="kcRevMeta-{{ section.id }}">{{ section.settings.reviews_meta_text }}</span>
        </div>
      </div>
      <div class="kc-rev__bars" id="kcRevBars-{{ section.id }}">
        {%- for i in (1..5) reversed -%}
          {%- assign bar_id = 'bar_' | append: i -%}
          <div class="kc-rev__bar-row">
            <span class="kc-rev__bar-label">{{ i }}★</span>
            <div class="kc-rev__bar-track">
              <div class="kc-rev__bar-fill" style="width:{{ section.settings[bar_id] }}%;" data-star="{{ i }}"></div>
            </div>
            <span class="kc-rev__bar-pct" data-pct-star="{{ i }}">{{ section.settings[bar_id] }}%</span>
          </div>
        {%- endfor -%}
      </div>
    </div>
    <div class="kc-rev__widget">
      {%- render 'judgeme_widgets', widget_type: 'judgeme_review_widget', concierge_install: true, product: product -%}
    </div>
  </div>
</div>

<style>
  .kc-reviews-section {
    padding: 28px 16px;
    background: {{ section.settings.bg_color }};
    font-family: '{{ section.settings.body_font }}', sans-serif;
  }
  .kc-rev__inner { max-width: 900px; margin: 0 auto; }
  .kc-rev__label {
    font-size: 12px; font-weight: 800; text-transform: uppercase;
    letter-spacing: .08em; color: {{ section.settings.brand_color }};
    margin-bottom: 16px; text-align: center;
  }
  .kc-rev__summary {
    display: flex; gap: 24px; align-items: center;
    margin-bottom: 24px; flex-wrap: wrap;
  }
  .kc-rev__score-wrap { display: flex; flex-direction: column; align-items: center; min-width: 80px; }
  .kc-rev__big-score {
    font-size: 48px; font-weight: 900; color: {{ section.settings.text_color }};
    line-height: 1;
  }
  .kc-rev__stars-row { display: flex; flex-direction: column; align-items: center; gap: 2px; margin-top: 4px; }
  .kc-rev__stars { color: {{ section.settings.star_color }}; font-size: 18px; letter-spacing: 1px; }
  .kc-rev__meta { font-size: 12px; color: {{ section.settings.muted_color }}; font-weight: 700; text-align: center; }
  .kc-rev__bars { flex: 1; display: flex; flex-direction: column; gap: 6px; min-width: 180px; }
  .kc-rev__bar-row { display: flex; align-items: center; gap: 8px; }
  .kc-rev__bar-label { font-size: 12px; font-weight: 800; color: {{ section.settings.muted_color }}; min-width: 22px; text-align: right; }
  .kc-rev__bar-track {
    flex: 1; height: 8px; background: #EDE8E0; border-radius: 4px; overflow: hidden;
  }
  .kc-rev__bar-fill { height: 100%; background: {{ section.settings.star_color }}; border-radius: 4px; transition: width 0.5s ease; }
  .kc-rev__bar-pct { font-size: 11px; color: {{ section.settings.muted_color }}; font-weight: 700; min-width: 30px; }
  @media (min-width: 768px) {
    .kc-reviews-section { padding: 36px 32px; }
  }
</style>

<script>
(function() {
  var handle = '{{ product.handle }}';
  fetch('/a/judgeme/widgets/judgeme_reviews?handle=' + handle)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data || !data.rating) return;
      var scoreEl = document.getElementById('kcRevScore-{{ section.id }}');
      var metaEl = document.getElementById('kcRevMeta-{{ section.id }}');
      if (scoreEl) scoreEl.textContent = parseFloat(data.rating).toFixed(1);
      if (metaEl && data.count) metaEl.textContent = 'Based on ' + data.count + ' reviews';
      if (data.rating_distribution) {
        var dist = data.rating_distribution;
        var total = Object.values(dist).reduce(function(a, b) { return a + b; }, 0);
        for (var star = 1; star <= 5; star++) {
          var count = dist[star] || 0;
          var pct = total > 0 ? Math.round(count * 100 / total) : 0;
          var fill = document.querySelector('[data-star="' + star + '"]');
          var pctEl = document.querySelector('[data-pct-star="' + star + '"]');
          if (fill) fill.style.width = pct + '%';
          if (pctEl) pctEl.textContent = pct + '%';
        }
      }
    })
    .catch(function() {});
})();
</script>

{% schema %}
{
  "name": "KC — Product Reviews",
  "settings": [
    { "type": "text", "id": "reviews_label", "label": "Section label", "default": "What parents are saying" },
    { "type": "text", "id": "reviews_meta_text", "label": "Review meta text", "default": "Based on verified reviews" },
    { "type": "range", "id": "bar_5", "label": "5-star %", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 72 },
    { "type": "range", "id": "bar_4", "label": "4-star %", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 18 },
    { "type": "range", "id": "bar_3", "label": "3-star %", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 6 },
    { "type": "range", "id": "bar_2", "label": "2-star %", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 2 },
    { "type": "range", "id": "bar_1", "label": "1-star %", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 2 },
    { "type": "color", "id": "brand_color", "label": "Brand colour", "default": "#6B5FD4" },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#2C2A3A" },
    { "type": "color", "id": "muted_color", "label": "Muted colour", "default": "#7A7890" },
    { "type": "color", "id": "success_color", "label": "Success colour", "default": "#4A7C6F" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#FBF8F4" },
    { "type": "color", "id": "star_color", "label": "Star colour", "default": "#E8C14A" },
    {
      "type": "select", "id": "body_font", "label": "Font",
      "options": [
        { "value": "Nunito", "label": "Nunito" },
        { "value": "Poppins", "label": "Poppins" },
        { "value": "Inter", "label": "Inter" },
        { "value": "DM Sans", "label": "DM Sans" },
        { "value": "Raleway", "label": "Raleway" }
      ],
      "default": "Nunito"
    }
  ],
  "presets": [
    {
      "name": "KC \u2014 Product Reviews"
    }
  ]
}
{% endschema %}
