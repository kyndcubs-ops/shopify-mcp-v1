{%- liquid
  assign wa_num = section.settings.whatsapp_number
  assign wa_msg = 'Hi! I would like to know more about ' | append: product.title | url_encode
  assign wa_link = 'https://wa.me/' | append: wa_num | append: '?text=' | append: wa_msg
-%}
<div id="shopify-section-{{ section.id }}" class="kc-wa-float">
  <a href="{{ wa_link }}" target="_blank" rel="noopener" class="kc-wa-float__btn" aria-label="Chat on WhatsApp"
    style="background:{{ section.settings.wa_color }};">
    💬
  </a>
</div>

<style>
  #shopify-section-{{ section.id }} .kc-wa-float {
    position: fixed;
    bottom: 70px;
    right: 16px;
    z-index: 800;
  }
  #shopify-section-{{ section.id }} .kc-wa-float__btn {
    display: flex; align-items: center; justify-content: center;
    width: 52px; height: 52px; border-radius: 50%;
    font-size: 26px; text-decoration: none;
    box-shadow: 0 4px 16px rgba(37,211,102,.4);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  #shopify-section-{{ section.id }} .kc-wa-float__btn:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 20px rgba(37,211,102,.5);
  }
  @media (min-width: 900px) {
    #shopify-section-{{ section.id }} .kc-wa-float { bottom: 24px; }
  }
</style>

{% schema %}
{
  "name": "KC — WhatsApp Float",
  "settings": [
    { "type": "text", "id": "whatsapp_number", "label": "WhatsApp number", "default": "917509802310" },
    { "type": "color", "id": "wa_color", "label": "Button colour", "default": "#25D366" }
  ],
  "presets": [
    {
      "name": "KC \u2014 WhatsApp Float"
    }
  ]
}
{% endschema %}
