{%- liquid
  assign wa_num = section.settings.wa_number
  assign wa_msg = 'Check out this product: ' | append: product.title
  assign wa_link = 'https://wa.me/' | append: wa_num | append: '?text=' | append: wa_msg | url_encode
-%}
<div id="shopify-section-{{ section.id }}" class="kcp-gallery">
  <div class="kcp-gallery__main-wrap">
    <div class="kcp-gallery__main" id="kcGalleryMain-{{ section.id }}">
      {%- for image in product.images -%}
        <div class="kcp-gallery__slide{% if forloop.first %} kcp-gallery__slide--active{% endif %}" data-index="{{ forloop.index0 }}">
          <img src="{{ image | image_url: width: 800 }}" alt="{{ image.alt | default: product.title | escape }}" width="800" height="800" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
        </div>
      {%- else -%}
        <div class="kcp-gallery__slide kcp-gallery__slide--active">
          <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title | escape }}" width="800" height="800" loading="eager">
        </div>
      {%- endfor -%}
    </div>
    <a href="{{ wa_link }}" target="_blank" rel="noopener" class="kcp-gallery__wa-share" aria-label="Share on WhatsApp">📤</a>
    <div class="kcp-gallery__dots">
      {%- for image in product.images -%}
        <button class="kcp-gallery__dot{% if forloop.first %} kcp-gallery__dot--active{% endif %}" data-dot="{{ forloop.index0 }}" aria-label="Image {{ forloop.index }}" type="button"></button>
      {%- endfor -%}
    </div>
  </div>
  {%- if product.images.size > 1 -%}
    <div class="kcp-gallery__thumbs" id="kcGalleryThumbs-{{ section.id }}">
      {%- for image in product.images -%}
        <button class="kcp-gallery__thumb{% if forloop.first %} kcp-gallery__thumb--active{% endif %}" data-thumb="{{ forloop.index0 }}" type="button" aria-label="View image {{ forloop.index }}">
          <img src="{{ image | image_url: width: 120 }}" alt="{{ image.alt | default: product.title | escape }}" width="120" height="120" loading="lazy">
        </button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

<style>
  #shopify-section-{{ section.id }} .kcp-gallery {
    position: relative;
    width: 100%;
  }
  #shopify-section-{{ section.id }} .kcp-gallery__main-wrap {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background-color: #F0EBE3;
    aspect-ratio: 1/1;
    touch-action: pan-y;
    user-select: none;
  }
  #shopify-section-{{ section.id }} .kcp-gallery__main {
    display: flex;
    width: 100%;
    height: 100%;
    position: relative;
  }
  #shopify-section-{{ section.id }} .kcp-gallery__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  #shopify-section-{{ section.id }} .kcp-gallery__slide--active { opacity: 1; z-index: 1; }
  #shopify-section-{{ section.id }} .kcp-gallery__slide img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  #shopify-section-{{ section.id }} .kcp-gallery__wa-share {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 10;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: #FFFFFF;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
    text-decoration: none;
    transition: transform 0.2s;
  }
  #shopify-section-{{ section.id }} .kcp-gallery__wa-share:hover { transform: scale(1.1); }
  #shopify-section-{{ section.id }} .kcp-gallery__dots {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    z-index: 10;
  }
  #shopify-section-{{ section.id }} .kcp-gallery__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: rgba(255,255,255,0.5);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.2s;
  }
  #shopify-section-{{ section.id }} .kcp-gallery__dot--active { background-color: #FFFFFF; }
  #shopify-section-{{ section.id }} .kcp-gallery__thumbs {
    display: flex;
    gap: 8px;
    margin-top: 10px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 2px;
  }
  #shopify-section-{{ section.id }} .kcp-gallery__thumbs::-webkit-scrollbar { display: none; }
  #shopify-section-{{ section.id }} .kcp-gallery__thumb {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    border-radius: 10px;
    overflow: hidden;
    border: 2px solid transparent;
    cursor: pointer;
    padding: 0;
    background: none;
    transition: border-color 0.2s;
  }
  #shopify-section-{{ section.id }} .kcp-gallery__thumb--active { border-color: #6B5FD4; }
  #shopify-section-{{ section.id }} .kcp-gallery__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .kcp-gallery {
      position: sticky;
      top: 20px;
      width: 480px;
      flex-shrink: 0;
    }
    #shopify-section-{{ section.id }} .kcp-gallery__dots { display: none; }
    #shopify-section-{{ section.id }} .kcp-gallery__thumb { width: 72px; height: 72px; }
  }
</style>

<script>
(function() {
  var sectionId = '{{ section.id }}';
  var wrap = document.querySelector('#shopify-section-' + sectionId + ' .kcp-gallery__main-wrap');
  if (!wrap) return;
  var slides = wrap.querySelectorAll('.kcp-gallery__slide');
  var dots = wrap.querySelectorAll('.kcp-gallery__dot');
  var thumbBtns = document.querySelectorAll('#shopify-section-' + sectionId + ' .kcp-gallery__thumb');
  var current = 0;
  var total = slides.length;
  if (total < 2) return;

  function goTo(idx) {
    slides[current].classList.remove('kcp-gallery__slide--active');
    if (dots[current]) dots[current].classList.remove('kcp-gallery__dot--active');
    if (thumbBtns[current]) thumbBtns[current].classList.remove('kcp-gallery__thumb--active');
    current = (idx + total) % total;
    slides[current].classList.add('kcp-gallery__slide--active');
    if (dots[current]) dots[current].classList.add('kcp-gallery__dot--active');
    if (thumbBtns[current]) thumbBtns[current].classList.add('kcp-gallery__thumb--active');
  }

  dots.forEach(function(dot) {
    dot.addEventListener('click', function() { goTo(parseInt(dot.getAttribute('data-dot'))); });
  });
  thumbBtns.forEach(function(btn) {
    btn.addEventListener('click', function() { goTo(parseInt(btn.getAttribute('data-thumb'))); });
  });

  // Touch & mouse swipe
  var startX = 0;
  var dragging = false;
  wrap.addEventListener('mousedown', function(e) { startX = e.clientX; dragging = true; });
  wrap.addEventListener('mousemove', function(e) { if (!dragging) return; });
  wrap.addEventListener('mouseup', function(e) {
    if (!dragging) return;
    dragging = false;
    var diff = e.clientX - startX;
    if (Math.abs(diff) > 40) { goTo(diff < 0 ? current + 1 : current - 1); }
  });
  wrap.addEventListener('mouseleave', function() { dragging = false; });
  wrap.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, { passive: true });
  wrap.addEventListener('touchend', function(e) {
    var diff = e.changedTouches[0].clientX - startX;
    if (Math.abs(diff) > 40) { goTo(diff < 0 ? current + 1 : current - 1); }
  });
})();
</script>

{% schema %}
{
  "name": "Product Gallery",
  "settings": [
    {
      "type": "text",
      "id": "wa_number",
      "label": "WhatsApp number",
      "default": "917509802310"
    }
  ],
  "presets": [
    {
      "name": "Product Gallery"
    }
  ]
}
{% endschema %}
