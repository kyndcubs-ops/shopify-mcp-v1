{%- liquid
  assign heading = section.settings.heading
  assign collection = collections[section.settings.collection]
  assign products_to_show = section.settings.products_to_show
-%}
<div id="shopify-section-{{ section.id }}" class="kc-best-sellers">
  <div class="kc-best-sellers__inner">
    <h2 class="kc-bs__heading">{{ heading }}</h2>
    <div class="kc-bs__track">
      {%- if collection != blank -%}
        {%- for product in collection.products limit: products_to_show -%}
          {%- liquid
            assign cv = product.selected_or_first_available_variant
            assign has_compare = false
            if cv.compare_at_price > cv.price
              assign has_compare = true
              assign save_pct = cv.compare_at_price | minus: cv.price | times: 100 | divided_by: cv.compare_at_price
            endif
            assign review_score = product.metafields.custom.review_score | default: '4.8'
            assign review_count = product.metafields.custom.review_count | default: '0'
            assign age_range = product.metafields.custom.age_range | default: ''
          -%}
          <div class="kc-bs__card">
            <a href="{{ product.url }}" class="kc-bs__img-link">
              <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}" width="400" height="400" loading="lazy">
              {%- if age_range != blank -%}
                <span class="kc-bs__age-badge">{{ age_range }}</span>
              {%- endif -%}
            </a>
            <div class="kc-bs__body">
              <a href="{{ product.url }}" class="kc-bs__title">{{ product.title }}</a>
              <div class="kc-bs__stars">
                {%- assign score_int = review_score | floor -%}
                {%- for i in (1..5) -%}
                  {%- if i <= score_int -%}
                    <span class="kc-bs__star kc-bs__star--full">★</span>
                  {%- else -%}
                    <span class="kc-bs__star kc-bs__star--empty">★</span>
                  {%- endif -%}
                {%- endfor -%}
                <span class="kc-bs__score">{{ review_score }}</span>
                {%- if review_count != '0' and review_count != '' -%}
                  <span class="kc-bs__count">({{ review_count }})</span>
                {%- endif -%}
              </div>
              <div class="kc-bs__price-row">
                <span class="kc-bs__price">{{ cv.price | money }}</span>
                {%- if has_compare -%}
                  <span class="kc-bs__mrp">{{ cv.compare_at_price | money }}</span>
                  <span class="kc-bs__save">{{ save_pct }}% off</span>
                {%- endif -%}
              </div>
              <button class="kc-btn-primary kc-bs__atc" data-variant-id="{{ cv.id }}" type="button">Add to cart</button>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <p class="kc-bs__empty">Select a collection in the Customizer.</p>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} .kc-best-sellers {
    background-color: #FBF8F4;
    padding: 32px 0;
  }
  #shopify-section-{{ section.id }} .kc-best-sellers__inner { max-width: 1200px; margin: 0 auto; }
  #shopify-section-{{ section.id }} .kc-bs__heading {
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 24px;
    color: #2C2A3A;
    text-align: center;
    margin-bottom: 20px;
    padding: 0 16px;
  }
  #shopify-section-{{ section.id }} .kc-bs__track {
    display: flex;
    gap: 14px;
    overflow-x: auto;
    padding: 8px 16px 16px;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  #shopify-section-{{ section.id }} .kc-bs__track::-webkit-scrollbar { display: none; }
  #shopify-section-{{ section.id }} .kc-bs__empty { padding: 16px; color: #7A7890; font-family: 'Nunito', sans-serif; }
  #shopify-section-{{ section.id }} .kc-bs__card {
    flex-shrink: 0;
    width: calc(100vw / 2.2 - 20px);
    background-color: #FFFFFF;
    border-radius: 14px;
    border: 1.5px solid #EDE8E0;
    overflow: hidden;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
  }
  #shopify-section-{{ section.id }} .kc-bs__img-link {
    position: relative;
    display: block;
    aspect-ratio: 1/1;
    overflow: hidden;
    background-color: #F0EBE3;
  }
  #shopify-section-{{ section.id }} .kc-bs__img-link img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  #shopify-section-{{ section.id }} .kc-bs__img-link:hover img { transform: scale(1.04); }
  #shopify-section-{{ section.id }} .kc-bs__age-badge {
    position: absolute;
    top: 8px;
    left: 8px;
    background-color: #F0EDFF;
    color: #6B5FD4;
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    font-size: 11px;
    padding: 3px 10px;
    border-radius: 99px;
    border: 1.5px solid #DDD8FF;
  }
  #shopify-section-{{ section.id }} .kc-bs__body {
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }
  #shopify-section-{{ section.id }} .kc-bs__title {
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    font-size: 14px;
    color: #2C2A3A;
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.3;
  }
  #shopify-section-{{ section.id }} .kc-bs__stars { display: flex; align-items: center; gap: 2px; }
  #shopify-section-{{ section.id }} .kc-bs__star { font-size: 13px; }
  #shopify-section-{{ section.id }} .kc-bs__star--full { color: #E8C14A; }
  #shopify-section-{{ section.id }} .kc-bs__star--empty { color: #EDE8E0; }
  #shopify-section-{{ section.id }} .kc-bs__score {
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    font-size: 12px;
    color: #2C2A3A;
    margin-left: 2px;
  }
  #shopify-section-{{ section.id }} .kc-bs__count { font-size: 11px; color: #7A7890; }
  #shopify-section-{{ section.id }} .kc-bs__price-row { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  #shopify-section-{{ section.id }} .kc-bs__price {
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 16px;
    color: #2C2A3A;
  }
  #shopify-section-{{ section.id }} .kc-bs__mrp {
    font-size: 13px;
    color: #7A7890;
    text-decoration: line-through;
  }
  #shopify-section-{{ section.id }} .kc-bs__save {
    font-size: 11px;
    font-weight: 800;
    color: #FFFFFF;
    background-color: #4A7C6F;
    padding: 2px 7px;
    border-radius: 99px;
  }
  #shopify-section-{{ section.id }} .kc-bs__atc {
    width: 100%;
    height: 40px;
    font-size: 13px;
    margin-top: auto;
    padding: 0 12px;
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .kc-best-sellers { padding: 48px 40px; }
    #shopify-section-{{ section.id }} .kc-bs__heading { font-size: 32px; margin-bottom: 28px; padding: 0; }
    #shopify-section-{{ section.id }} .kc-bs__track {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      overflow-x: visible;
      padding: 0;
      gap: 20px;
    }
    #shopify-section-{{ section.id }} .kc-bs__card { width: auto; }
    #shopify-section-{{ section.id }} .kc-bs__title { font-size: 15px; }
    #shopify-section-{{ section.id }} .kc-bs__price { font-size: 18px; }
    #shopify-section-{{ section.id }} .kc-bs__atc { height: 44px; font-size: 14px; }
  }
  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .kc-best-sellers { padding: 64px 60px; }
    #shopify-section-{{ section.id }} .kc-bs__heading { font-size: 36px; }
    #shopify-section-{{ section.id }} .kc-bs__track { gap: 24px; }
    #shopify-section-{{ section.id }} .kc-bs__title { font-size: 16px; }
    #shopify-section-{{ section.id }} .kc-bs__price { font-size: 20px; }
    #shopify-section-{{ section.id }} .kc-bs__atc { height: 48px; font-size: 15px; }
  }
</style>

<script>
(function() {
  var section = document.getElementById('shopify-section-{{ section.id }}');
  if (!section) return;
  section.addEventListener('click', function(e) {
    var btn = e.target.closest('.kc-bs__atc');
    if (!btn) return;
    e.preventDefault();
    var variantId = btn.getAttribute('data-variant-id');
    if (!variantId) return;
    btn.disabled = true;
    btn.textContent = 'Adding…';
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(function(r) { return r.json(); })
    .then(function() {
      btn.textContent = '✓ Added!';
      return fetch('/cart.js');
    })
    .then(function(r) { return r.json(); })
    .then(function(cart) {
      var count = cart.item_count;
      document.querySelectorAll('.cart-count-bubble').forEach(function(el) {
        el.removeAttribute('hidden');
        var span = el.querySelector('span[aria-hidden]') || el.querySelector('span');
        if (span) span.textContent = count;
      });
      setTimeout(function() { btn.textContent = 'Add to cart'; btn.disabled = false; }, 2000);
    })
    .catch(function() { btn.textContent = 'Add to cart'; btn.disabled = false; });
  });
})();
</script>

{% schema %}
{
  "name": "Best Sellers",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Our best sellers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 12,
      "step": 4,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Best Sellers"
    }
  ]
}
{% endschema %}
