<div id="shopify-section-{{ section.id }}" class="kc-brand-story">
  <div class="kc-brand-story__inner">
    {%- if section.settings.image != blank -%}
      <div class="kc-brand-story__img">
        <img src="{{ section.settings.image | image_url: width: 600 }}" alt="{{ section.settings.heading | escape }}" width="600" height="480" loading="lazy">
      </div>
    {%- endif -%}
    <div class="kc-brand-story__content">
      <h2 class="kc-brand-story__heading">{{ section.settings.heading }}</h2>
      <div class="kc-brand-story__body">{{ section.settings.body_text }}</div>
      {%- if section.blocks.size > 0 -%}
        <div class="kc-brand-story__stats">
          {%- for block in section.blocks -%}
            <div class="kc-bs-stat" {{ block.shopify_attributes }}>
              <span class="kc-bs-stat__value">{{ block.settings.value }}</span>
              <span class="kc-bs-stat__label">{{ block.settings.label }}</span>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} .kc-brand-story {
    background-color: #F0EBE3;
    padding: 40px 16px;
  }
  #shopify-section-{{ section.id }} .kc-brand-story__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }
  #shopify-section-{{ section.id }} .kc-brand-story__img { border-radius: 16px; overflow: hidden; }
  #shopify-section-{{ section.id }} .kc-brand-story__img img { width: 100%; height: auto; display: block; }
  #shopify-section-{{ section.id }} .kc-brand-story__heading {
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 26px;
    color: #2C2A3A;
    margin-bottom: 14px;
    line-height: 1.25;
  }
  #shopify-section-{{ section.id }} .kc-brand-story__body {
    font-family: 'Nunito', sans-serif;
    font-size: 16px;
    color: #7A7890;
    line-height: 1.7;
    margin-bottom: 24px;
  }
  #shopify-section-{{ section.id }} .kc-brand-story__stats {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  #shopify-section-{{ section.id }} .kc-bs-stat {
    background-color: #FFFFFF;
    border-radius: 14px;
    border: 1.5px solid #EDE8E0;
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 1;
    min-width: 120px;
  }
  #shopify-section-{{ section.id }} .kc-bs-stat__value {
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 22px;
    color: #6B5FD4;
    line-height: 1;
    margin-bottom: 4px;
  }
  #shopify-section-{{ section.id }} .kc-bs-stat__label {
    font-size: 12px;
    color: #7A7890;
    font-weight: 700;
    text-align: center;
    line-height: 1.3;
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .kc-brand-story { padding: 60px 40px; }
    #shopify-section-{{ section.id }} .kc-brand-story__inner { flex-direction: row; align-items: center; gap: 48px; }
    #shopify-section-{{ section.id }} .kc-brand-story__img { flex: 0 0 40%; }
    #shopify-section-{{ section.id }} .kc-brand-story__content { flex: 1; }
    #shopify-section-{{ section.id }} .kc-brand-story__heading { font-size: 34px; }
    #shopify-section-{{ section.id }} .kc-brand-story__body { font-size: 17px; }
    #shopify-section-{{ section.id }} .kc-bs-stat__value { font-size: 28px; }
  }
</style>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We're parents too."
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Story body",
      "default": "<p>We got tired of toys abandoned in 3 days. We built Kynd Cubs to fix that — handpicking only the toys that genuinely hold a child's attention, build real skills, and are safe for Indian homes.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Brand image (optional)"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Stat value",
          "default": "1 in 5"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Stat label",
          "default": "products make our list"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Story",
      "blocks": [
        { "type": "stat", "settings": { "value": "1 in 5", "label": "products make our list" } },
        { "type": "stat", "settings": { "value": "50+", "label": "families tested" } },
        { "type": "stat", "settings": { "value": "100%", "label": "safe certified" } }
      ]
    }
  ]
}
{% endschema %}
