<script>
(function() {
  var sectionId = '{{ section.id }}';
  var freeThreshold = {{ free_threshold | times: 100 }};
  var section = document.getElementById('shopify-section-' + sectionId);
  if (!section) return;

  function updateCartDisplay(cart) {
    // Update count bubble
    var count = cart.item_count;
    document.querySelectorAll('.cart-count-bubble').forEach(function(el) {
      el.removeAttribute('hidden');
      var span = el.querySelector('span[aria-hidden]') || el.querySelector('span');
      if (span) span.textContent = count;
    });

    // Update subtotal/total
    var subtotalEl = document.getElementById('kcCartSubtotal-' + sectionId);
    var totalEl = document.getElementById('kcCartTotal-' + sectionId);
    var checkoutBtn = document.getElementById('kcCheckoutBtn-' + sectionId);
    var formatted = (cart.total_price / 100).toLocaleString('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 });
    if (subtotalEl) subtotalEl.textContent = formatted;
    if (totalEl) totalEl.textContent = formatted;
    if (checkoutBtn) checkoutBtn.textContent = 'Checkout · ' + formatted;

    // Progress bar
    var fill = document.getElementById('kcCartProgress-' + sectionId);
    if (fill) {
      var pct = Math.min(100, Math.round(cart.total_price * 100 / freeThreshold));
      fill.style.width = pct + '%';
    }

    // Reload page if cart is empty (simpler UX)
    if (cart.item_count === 0) {
      window.location.reload();
    }
  }

  function cartPost(endpoint, body) {
    return fetch(endpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify(body)
    })
    .then(function(r) { return r.json(); })
    .then(function() { return fetch('/cart.js'); })
    .then(function(r) { return r.json(); });
  }

  // Qty and remove buttons
  section.addEventListener('click', function(e) {
    var minusBtn = e.target.closest('.kc-cart__qty-minus');
    var plusBtn = e.target.closest('.kc-cart__qty-plus');
    var removeBtn = e.target.closest('.kc-cart__remove');
    var upsellAtc = e.target.closest('.kc-cart__upsell-atc');

    if (minusBtn) {
      var key = minusBtn.getAttribute('data-key');
      var valEl = minusBtn.parentElement.querySelector('.kc-cart__qty-val');
      var currentQty = parseInt(valEl ? valEl.textContent : '1') || 1;
      var newQty = Math.max(0, currentQty - 1);
      cartPost('/cart/change.js', { id: key, quantity: newQty })
        .then(function(cart) {
          if (newQty === 0) {
            var item = section.querySelector('.kc-cart__item[data-key="' + key + '"]');
            if (item) item.remove();
          } else {
            if (valEl) valEl.textContent = newQty;
          }
          updateCartDisplay(cart);
        });
    }

    if (plusBtn) {
      var key = plusBtn.getAttribute('data-key');
      var valEl = plusBtn.parentElement.querySelector('.kc-cart__qty-val');
      var currentQty = parseInt(valEl ? valEl.textContent : '1') || 1;
      cartPost('/cart/change.js', { id: key, quantity: currentQty + 1 })
        .then(function(cart) {
          if (valEl) valEl.textContent = currentQty + 1;
          updateCartDisplay(cart);
        });
    }

    if (removeBtn) {
      var key = removeBtn.getAttribute('data-key');
      cartPost('/cart/change.js', { id: key, quantity: 0 })
        .then(function(cart) {
          var item = section.querySelector('.kc-cart__item[data-key="' + key + '"]');
          if (item) item.remove();
          updateCartDisplay(cart);
        });
    }

    if (upsellAtc) {
      var variantId = upsellAtc.getAttribute('data-variant-id');
      var productId = upsellAtc.getAttribute('data-product-id');
      upsellAtc.disabled = true;
      upsellAtc.textContent = '✓';
      cartPost('/cart/add.js', { id: variantId, quantity: 1 })
        .then(function(cart) {
          // Hide this upsell card
          var card = section.querySelector('.kc-cart__upsell-card[data-product-id="' + productId + '"]');
          if (card) card.classList.add('kc-cart__upsell-card--hidden');
          updateCartDisplay(cart);
        })
        .catch(function() { upsellAtc.textContent = '+ Add'; upsellAtc.disabled = false; });
    }
  });

  // Discount code
  var applyBtn = document.getElementById('kcApplyDiscount-' + sectionId);
  if (applyBtn) {
    applyBtn.addEventListener('click', function() {
      var codeInput = document.getElementById('kcDiscountCode-' + sectionId);
      var code = codeInput ? codeInput.value.trim() : '';
      if (code) {
        window.location.href = '/discount/' + encodeURIComponent(code) + '?redirect=/cart';
      }
    });
  }
})();
</script>

{% schema %}
{
  "name": "Cart Page",
  "settings": [
    {
      "type": "number",
      "id": "free_shipping_threshold",
      "label": "Free shipping threshold (₹)",
      "default": 499
    },
    {
      "type": "collection",
      "id": "upsell_collection",
      "label": "Upsell collection"
    },
    {
      "type": "text",
      "id": "upsell_heading",
      "label": "Upsell section heading",
      "default": "You may also love"
    },
    {
      "type": "text",
      "id": "wa_number",
      "label": "WhatsApp number",
      "default": "917509802310"
    }
  ],
  "presets": [
    {
      "name": "Cart Page"
    }
  ]
}
{% endschema %}
