{%- liquid
  assign free_threshold = section.settings.free_shipping_threshold
  assign wa_num = section.settings.wa_number
  assign wa_msg = 'Hi! I need help with my order.'
  assign wa_msg_enc = wa_msg | url_encode
  assign wa_link = 'https://wa.me/' | append: wa_num | append: '?text=' | append: wa_msg_enc
  assign cart_total = cart.total_price
  assign remaining = free_threshold | times: 100 | minus: cart_total
  assign progress_pct = cart_total | times: 100 | divided_by: free_threshold | divided_by: 100
  if progress_pct > 100
    assign progress_pct = 100
  endif
  assign upsell_col = collections[section.settings.upsell_collection]
-%}
<div id="shopify-section-{{ section.id }}" class="kc-cart-page">
  <div class="kc-cart__inner">
    <h1 class="kc-cart__title">Your cart</h1>

    <div class="kc-cart__progress-bar-wrap">
      {%- if remaining > 0 -%}
        <p class="kc-cart__progress-text">Add <strong>{{ remaining | money }}</strong> more for free delivery 🚚</p>
      {%- else -%}
        <p class="kc-cart__progress-text kc-cart__progress-text--done">🎉 You've unlocked free delivery!</p>
      {%- endif -%}
      <div class="kc-cart__progress-track">
        <div class="kc-cart__progress-fill" id="kcCartProgress-{{ section.id }}" style="width: {{ progress_pct }}%"></div>
      </div>
    </div>

    {%- if cart.items.size > 0 -%}
      <div class="kc-cart__items" id="kcCartItems-{{ section.id }}">
        {%- for item in cart.items -%}
          <div class="kc-cart__item" data-key="{{ item.key }}">
            <div class="kc-cart__item-img">
              <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title | escape }}" width="160" height="160" loading="lazy">
            </div>
            <div class="kc-cart__item-details">
              <a href="{{ item.url }}" class="kc-cart__item-title">{{ item.product.title }}</a>
              {%- unless item.variant.title == 'Default Title' -%}
                <p class="kc-cart__item-variant">{{ item.variant.title }}</p>
              {%- endunless -%}
              <div class="kc-cart__item-price-row">
                <span class="kc-cart__item-price">{{ item.final_price | money }}</span>
                {%- if item.original_price > item.final_price -%}
                  <span class="kc-cart__item-mrp">{{ item.original_price | money }}</span>
                {%- endif -%}
              </div>
              <div class="kc-cart__item-qty">
                <button type="button" class="kc-cart__qty-btn kc-cart__qty-minus" data-key="{{ item.key }}" aria-label="Decrease">−</button>
                <span class="kc-cart__qty-val">{{ item.quantity }}</span>
                <button type="button" class="kc-cart__qty-btn kc-cart__qty-plus" data-key="{{ item.key }}" aria-label="Increase">+</button>
                <button type="button" class="kc-cart__remove" data-key="{{ item.key }}" aria-label="Remove">✕</button>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- if upsell_col != blank and upsell_col.products.size > 0 -%}
        <div class="kc-cart__upsell" id="kcCartUpsell-{{ section.id }}">
          <h3 class="kc-cart__upsell-title">{{ section.settings.upsell_heading }}</h3>
          <div class="kc-cart__upsell-track">
            {%- for up_product in upsell_col.products limit: 6 -%}
              {%- assign upcv = up_product.selected_or_first_available_variant -%}
              {%- assign already_in_cart = false -%}
              {%- for item in cart.items -%}
                {%- if item.product_id == up_product.id -%}
                  {%- assign already_in_cart = true -%}
                {%- endif -%}
              {%- endfor -%}
              <div class="kc-cart__upsell-card{% if already_in_cart %} kc-cart__upsell-card--hidden{% endif %}" data-product-id="{{ up_product.id }}">
                <img src="{{ up_product.featured_image | image_url: width: 160 }}" alt="{{ up_product.title | escape }}" width="160" height="160" loading="lazy">
                <span class="kc-cart__upsell-name">{{ up_product.title | truncate: 30 }}</span>
                <span class="kc-cart__upsell-price">{{ upcv.price | money }}</span>
                <button type="button" class="kc-btn-primary kc-cart__upsell-atc" data-variant-id="{{ upcv.id }}" data-product-id="{{ up_product.id }}">+ Add</button>
              </div>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      <div class="kc-cart__discount">
        <h3 class="kc-cart__discount-title">Have a discount code?</h3>
        <div class="kc-cart__discount-row">
          <input type="text" id="kcDiscountCode-{{ section.id }}" class="kc-cart__discount-input" placeholder="Enter code">
          <button type="button" class="kc-btn-secondary kc-cart__discount-btn" id="kcApplyDiscount-{{ section.id }}">Apply</button>
        </div>
      </div>

      <div class="kc-cart__summary">
        <div class="kc-cart__summary-row">
          <span>Subtotal</span>
          <span class="kc-cart__subtotal" id="kcCartSubtotal-{{ section.id }}">{{ cart.total_price | money }}</span>
        </div>
        <div class="kc-cart__summary-row">
          <span>Delivery</span>
          <span id="kcCartDelivery-{{ section.id }}">
            {%- if remaining > 0 -%}
              Calculated at checkout
            {%- else -%}
              <span class="kc-cart__free-ship">FREE</span>
            {%- endif -%}
          </span>
        </div>
        {%- if cart.total_discount > 0 -%}
          <div class="kc-cart__summary-row kc-cart__summary-row--savings">
            <span>You save</span>
            <span class="kc-cart__savings">{{ cart.total_discount | money }}</span>
          </div>
        {%- endif -%}
        <div class="kc-cart__summary-row kc-cart__summary-total">
          <span>Total</span>
          <span id="kcCartTotal-{{ section.id }}">{{ cart.total_price | money }}</span>
        </div>
      </div>

      <a href="/checkout" class="kc-btn-primary kc-cart__checkout-btn" id="kcCheckoutBtn-{{ section.id }}">Checkout · {{ cart.total_price | money }}</a>

      <div class="kc-cart__cod-note">
        <span class="kc-cart__cod-icon">💵</span>
        <span>Cash on delivery available at checkout</span>
      </div>

      <div class="kc-cart__trust">
        <div class="kc-cart__trust-item"><span>✅</span> Safety tested</div>
        <div class="kc-cart__trust-item"><span>↩️</span> 7-day returns</div>
        <div class="kc-cart__trust-item"><span>🚚</span> Pan-India delivery</div>
        <div class="kc-cart__trust-item"><span>🔒</span> Secure checkout</div>
      </div>

      <div class="kc-cart__wa-help">
        <p>Need help? <a href="{{ wa_link }}" target="_blank" rel="noopener" class="kc-cart__wa-link">💬 Chat with us on WhatsApp</a></p>
      </div>

    {%- else -%}
      <div class="kc-cart__empty">
        <p>Your cart is empty.</p>
        <a href="/collections/all" class="kc-btn-primary">Shop now</a>
      </div>
    {%- endif -%}
  </div>
</div>

