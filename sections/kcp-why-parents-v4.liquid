      "id": "card1_emoji",
      "label": "Card 1 emoji",
      "default": "🧠"
    },
    {
      "type": "text",
      "id": "card1_title",
      "label": "Card 1 title",
      "default": "Builds real skills"
    },
    {
      "type": "text",
      "id": "card1_desc",
      "label": "Card 1 description",
      "default": "Designed around child development milestones."
    },
    {
      "type": "text",
      "id": "card2_emoji",
      "label": "Card 2 emoji",
      "default": "⏳"
    },
    {
      "type": "text",
      "id": "card2_title",
      "label": "Card 2 title",
      "default": "Long play time"
    },
    {
      "type": "text",
      "id": "card2_desc",
      "label": "Card 2 description",
      "default": "Not abandoned after 3 days — tested for longevity."
    },
    {
      "type": "text",
      "id": "card3_emoji",
      "label": "Card 3 emoji",
      "default": "✅"
    },
    {
      "type": "text",
      "id": "card3_title",
      "label": "Card 3 title",
      "default": "Certified safe"
    },
    {
      "type": "text",
      "id": "card3_desc",
      "label": "Card 3 description",
      "default": "Every product is EN71 & BIS tested."
    },
    {
      "type": "text",
      "id": "card4_emoji",
      "label": "Card 4 emoji",
      "default": "🎁"
    },
    {
      "type": "text",
      "id": "card4_title",
      "label": "Card 4 title",
      "default": "Gift-ready"
