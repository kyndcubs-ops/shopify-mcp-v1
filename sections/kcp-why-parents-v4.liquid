{%- liquid
  assign c1_emoji = product.metafields.custom.why_card_1_emoji | default: ''
  assign c1_title = product.metafields.custom.why_card_1_title | default: ''
  assign c1_desc = product.metafields.custom.why_card_1_desc | default: ''
  assign c2_emoji = product.metafields.custom.why_card_2_emoji | default: ''
  assign c2_title = product.metafields.custom.why_card_2_title | default: ''
  assign c2_desc = product.metafields.custom.why_card_2_desc | default: ''
  assign c3_emoji = product.metafields.custom.why_card_3_emoji | default: ''
  assign c3_title = product.metafields.custom.why_card_3_title | default: ''
  assign c3_desc = product.metafields.custom.why_card_3_desc | default: ''
  assign c4_emoji = product.metafields.custom.why_card_4_emoji | default: ''
  assign c4_title = product.metafields.custom.why_card_4_title | default: ''
  assign c4_desc = product.metafields.custom.why_card_4_desc | default: ''
-%}
<div id="shopify-section-{{ section.id }}" class="kcp-why-parents">
  <h2 class="kcp-wp__heading">{{ section.settings.heading }}</h2>
  <div class="kcp-wp__grid">
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        <div class="kcp-wp__card" {{ block.shopify_attributes }}>
          <span class="kcp-wp__emoji">{{ block.settings.emoji }}</span>
          <span class="kcp-wp__title">{{ block.settings.title }}</span>
          <p class="kcp-wp__desc">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="kcp-wp__card">
        <span class="kcp-wp__emoji">{{ c1_emoji | default: section.settings.card1_emoji }}</span>
        <span class="kcp-wp__title">{{ c1_title | default: section.settings.card1_title }}</span>
        <p class="kcp-wp__desc">{{ c1_desc | default: section.settings.card1_desc }}</p>
      </div>
      <div class="kcp-wp__card">
        <span class="kcp-wp__emoji">{{ c2_emoji | default: section.settings.card2_emoji }}</span>
        <span class="kcp-wp__title">{{ c2_title | default: section.settings.card2_title }}</span>
        <p class="kcp-wp__desc">{{ c2_desc | default: section.settings.card2_desc }}</p>
      </div>
      <div class="kcp-wp__card">
        <span class="kcp-wp__emoji">{{ c3_emoji | default: section.settings.card3_emoji }}</span>
        <span class="kcp-wp__title">{{ c3_title | default: section.settings.card3_title }}</span>
        <p class="kcp-wp__desc">{{ c3_desc | default: section.settings.card3_desc }}</p>
      </div>
      <div class="kcp-wp__card">
        <span class="kcp-wp__emoji">{{ c4_emoji | default: section.settings.card4_emoji }}</span>
        <span class="kcp-wp__title">{{ c4_title | default: section.settings.card4_title }}</span>
        <p class="kcp-wp__desc">{{ c4_desc | default: section.settings.card4_desc }}</p>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} .kcp-why-parents {
    padding: 28px 16px;
    background-color: #FBF8F4;
    font-family: 'Nunito', sans-serif;
  }
  #shopify-section-{{ section.id }} .kcp-wp__heading {
    font-weight: 900;
    font-size: 22px;
    color: #2C2A3A;
    margin-bottom: 18px;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .kcp-wp__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  #shopify-section-{{ section.id }} .kcp-wp__card {
    background-color: #FFFFFF;
    border-radius: 14px;
    border: 1.5px solid #EDE8E0;
    padding: 16px 14px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  #shopify-section-{{ section.id }} .kcp-wp__emoji { font-size: 26px; line-height: 1; }
  #shopify-section-{{ section.id }} .kcp-wp__title {
    font-weight: 800;
    font-size: 14px;
    color: #2C2A3A;
  }
  #shopify-section-{{ section.id }} .kcp-wp__desc {
    font-size: 13px;
    color: #7A7890;
    line-height: 1.4;
    margin: 0;
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .kcp-why-parents { padding: 32px 0; }
    #shopify-section-{{ section.id }} .kcp-wp__grid { grid-template-columns: repeat(4, 1fr); gap: 16px; }
    #shopify-section-{{ section.id }} .kcp-wp__title { font-size: 15px; }
    #shopify-section-{{ section.id }} .kcp-wp__desc { font-size: 14px; }
  }
  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .kcp-wp__grid { gap: 24px; }
    #shopify-section-{{ section.id }} .kcp-wp__title { font-size: 16px; }
    #shopify-section-{{ section.id }} .kcp-wp__desc { font-size: 15px; }
  }
</style>

