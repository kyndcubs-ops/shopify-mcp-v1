  "blocks": [
    {
      "type": "why_card",
      "name": "Why Card",
      "settings": [
        {
          "type": "text",
          "id": "emoji",
          "label": "Emoji",
          "default": "🧠"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Builds real skills"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Designed around child development milestones."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Parents Love It"
    }
  ]
}
{% endschema %}
