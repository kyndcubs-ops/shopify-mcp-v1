{%- liquid
  assign wc1_emoji = product.metafields.custom.why_card_1_emoji
  assign wc1_title = product.metafields.custom.why_card_1_title
  assign wc1_desc  = product.metafields.custom.why_card_1_desc
  assign wc2_emoji = product.metafields.custom.why_card_2_emoji
  assign wc2_title = product.metafields.custom.why_card_2_title
  assign wc2_desc  = product.metafields.custom.why_card_2_desc
  assign wc3_emoji = product.metafields.custom.why_card_3_emoji
  assign wc3_title = product.metafields.custom.why_card_3_title
  assign wc3_desc  = product.metafields.custom.why_card_3_desc
  assign wc4_emoji = product.metafields.custom.why_card_4_emoji
  assign wc4_title = product.metafields.custom.why_card_4_title
  assign wc4_desc  = product.metafields.custom.why_card_4_desc
  assign use_metafields = false
  if wc1_title != blank and wc2_title != blank
    assign use_metafields = true
  endif
-%}
<div id="shopify-section-{{ section.id }}" class="kc-why">
  <div class="kc-why__inner">
    {%- if section.settings.why_eyebrow != blank -%}
      <p class="kc-why__eyebrow">{{ section.settings.why_eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.why_title != blank -%}
      <h2 class="kc-why__title">
        {%- assign title_parts = section.settings.why_title | split: '[em]' -%}
        {%- for part in title_parts -%}
          {%- assign sub_parts = part | split: '[/em]' -%}
          {%- if forloop.index > 1 -%}
            <em>{{ sub_parts[0] }}</em>
            {%- if sub_parts.size > 1 -%}{{ sub_parts[1] }}{%- endif -%}
          {%- else -%}
            {{ part }}
          {%- endif -%}
        {%- endfor -%}
      </h2>
    {%- endif -%}
    <div class="kc-why__grid">
      {%- if use_metafields -%}
        <div class="kc-why__card">
          <span class="kc-why__emoji">{{ wc1_emoji | default: '🧠' }}</span>
          <p class="kc-why__card-title">{{ wc1_title }}</p>
          {%- if wc1_desc != blank -%}<p class="kc-why__card-desc">{{ wc1_desc }}</p>{%- endif -%}
        </div>
        <div class="kc-why__card">
          <span class="kc-why__emoji">{{ wc2_emoji | default: '🌿' }}</span>
          <p class="kc-why__card-title">{{ wc2_title }}</p>
          {%- if wc2_desc != blank -%}<p class="kc-why__card-desc">{{ wc2_desc }}</p>{%- endif -%}
        </div>
        {%- if wc3_title != blank -%}
          <div class="kc-why__card">
            <span class="kc-why__emoji">{{ wc3_emoji | default: '⏰' }}</span>
            <p class="kc-why__card-title">{{ wc3_title }}</p>
            {%- if wc3_desc != blank -%}<p class="kc-why__card-desc">{{ wc3_desc }}</p>{%- endif -%}
          </div>
        {%- endif -%}
        {%- if wc4_title != blank -%}
          <div class="kc-why__card">
            <span class="kc-why__emoji">{{ wc4_emoji | default: '🎁' }}</span>
            <p class="kc-why__card-title">{{ wc4_title }}</p>
            {%- if wc4_desc != blank -%}<p class="kc-why__card-desc">{{ wc4_desc }}</p>{%- endif -%}
          </div>
        {%- endif -%}
      {%- elsif section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'why_card' -%}
            <div class="kc-why__card" {{ block.shopify_attributes }}>
              <span class="kc-why__emoji">{{ block.settings.emoji }}</span>
              <p class="kc-why__card-title">{{ block.settings.title }}</p>
              {%- if block.settings.desc != blank -%}<p class="kc-why__card-desc">{{ block.settings.desc }}</p>{%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <div class="kc-why__card">
          <span class="kc-why__emoji">🧠</span>
          <p class="kc-why__card-title">Builds real skills</p>
          <p class="kc-why__card-desc">STEM learning through play</p>
        </div>
        <div class="kc-why__card">
          <span class="kc-why__emoji">🌿</span>
          <p class="kc-why__card-title">100% safe</p>
          <p class="kc-why__card-desc">Non-toxic, BPA-free, EN71 certified</p>
        </div>
        <div class="kc-why__card">
          <span class="kc-why__emoji">⏰</span>
          <p class="kc-why__card-title">Hours of play</p>
          <p class="kc-why__card-desc">Kids stay engaged 45+ min</p>
        </div>
        <div class="kc-why__card">
          <span class="kc-why__emoji">🎁</span>
          <p class="kc-why__card-title">Perfect gift</p>
          <p class="kc-why__card-desc">Premium box, ready to gift</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} .kc-why {
    padding: 28px 16px;
    background: {{ section.settings.card_bg }};
    font-family: '{{ section.settings.body_font }}', sans-serif;
  }
  #shopify-section-{{ section.id }} .kc-why__inner { max-width: 900px; margin: 0 auto; }
  #shopify-section-{{ section.id }} .kc-why__eyebrow {
    font-size: 12px; font-weight: 800; text-transform: uppercase;
    letter-spacing: .08em; color: {{ section.settings.brand_color }};
    margin-bottom: 6px; text-align: center;
  }
  #shopify-section-{{ section.id }} .kc-why__title {
    font-size: 22px; font-weight: 900; color: {{ section.settings.text_color }};
    text-align: center; margin-bottom: 22px; line-height: 1.3;
  }
  #shopify-section-{{ section.id }} .kc-why__title em { color: {{ section.settings.brand_color }}; font-style: normal; }
  #shopify-section-{{ section.id }} .kc-why__grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;
  }
  #shopify-section-{{ section.id }} .kc-why__card {
    background: {{ section.settings.why_card_bg }};
    border-radius: 14px; padding: 16px 14px;
    display: flex; flex-direction: column; gap: 6px; align-items: flex-start;
    border: 1.5px solid rgba(0,0,0,.06);
  }
  #shopify-section-{{ section.id }} .kc-why__emoji { font-size: 28px; line-height: 1; }
  #shopify-section-{{ section.id }} .kc-why__card-title {
    font-size: 14px; font-weight: 900; color: {{ section.settings.text_color }}; margin: 0;
  }
  #shopify-section-{{ section.id }} .kc-why__card-desc {
    font-size: 12px; color: {{ section.settings.muted_color }}; font-weight: 700; margin: 0;
    line-height: 1.4;
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .kc-why { padding: 36px 32px; }
    #shopify-section-{{ section.id }} .kc-why__grid { grid-template-columns: repeat(4, 1fr); gap: 16px; }
    #shopify-section-{{ section.id }} .kc-why__title { font-size: 26px; }
    #shopify-section-{{ section.id }} .kc-why__card-title { font-size: 15px; }
    #shopify-section-{{ section.id }} .kc-why__card-desc { font-size: 13px; }
  }
</style>

{% schema %}
{
  "name": "KC — Why Parents Love It",
  "settings": [
    { "type": "text", "id": "why_eyebrow", "label": "Eyebrow text", "default": "Trusted by 500+ families" },
    { "type": "text", "id": "why_title", "label": "Section title (use [em]...[/em] for highlight)", "default": "Why parents [em]love[/em] it" },
    { "type": "color", "id": "brand_color", "label": "Brand colour", "default": "#6B5FD4" },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#2C2A3A" },
    { "type": "color", "id": "muted_color", "label": "Muted colour", "default": "#7A7890" },
    { "type": "color", "id": "success_color", "label": "Success colour", "default": "#4A7C6F" },
    { "type": "color", "id": "card_bg", "label": "Section background", "default": "#F0EBE3" },
    { "type": "color", "id": "why_card_bg", "label": "Card background", "default": "#FFFFFF" },
    { "type": "range", "id": "border_radius", "label": "Card radius", "min": 0, "max": 24, "step": 1, "unit": "px", "default": 12 },
    {
      "type": "select", "id": "body_font", "label": "Font",
      "options": [
        { "value": "Nunito", "label": "Nunito" },
        { "value": "Poppins", "label": "Poppins" },
        { "value": "Inter", "label": "Inter" },
        { "value": "DM Sans", "label": "DM Sans" },
        { "value": "Raleway", "label": "Raleway" }
      ],
      "default": "Nunito"
    }
  ],
  "blocks": [
    {
      "type": "why_card",
      "name": "Why Card",
      "settings": [
        { "type": "text", "id": "emoji", "label": "Emoji icon", "default": "🧠" },
        { "type": "text", "id": "title", "label": "Card title", "default": "Builds real skills" },
        { "type": "text", "id": "desc", "label": "Card description", "default": "STEM learning through play" }
      ]
    }
  ],
  "presets": [
    {
      "name": "KC \u2014 Why Parents Love It"
    }
  ]
}
{% endschema %}
