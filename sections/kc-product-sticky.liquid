<div id="shopify-section-{{ section.id }}" class="kc-sticky-bar">
  <div class="kc-sticky__inner">
    <div class="kc-sticky__info">
      {%- assign sticky_title = product.title | truncate: 28 -%}
      <p class="kc-sticky__title">{{ sticky_title }}</p>
      <p class="kc-sticky__price" id="kc-sticky-price">{{ product.selected_or_first_available_variant.price | money }}</p>
    </div>
    <button type="button" class="kc-sticky__atc" id="kc-sticky-btn"
      style="background:{{ section.settings.brand_color }};">
      {{ section.settings.sticky_button_text }}
    </button>
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} .kc-sticky-bar {
    display: none;
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 900;
    background: {{ section.settings.sticky_bg }};
    border-top: 1.5px solid #EDE8E0;
    padding: 10px 16px 10px;
    box-shadow: 0 -2px 12px rgba(0,0,0,.1);
    font-family: '{{ section.settings.body_font }}', sans-serif;
  }
  #shopify-section-{{ section.id }} .kc-sticky__inner {
    display: flex; align-items: center; gap: 14px; max-width: 600px; margin: 0 auto;
  }
  #shopify-section-{{ section.id }} .kc-sticky__info { flex: 1; min-width: 0; }
  #shopify-section-{{ section.id }} .kc-sticky__title {
    font-size: 13px; font-weight: 800; color: #2C2A3A;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin: 0;
  }
  #shopify-section-{{ section.id }} .kc-sticky__price {
    font-size: 16px; font-weight: 900; color: {{ section.settings.brand_color }};
    margin: 2px 0 0;
  }
  #shopify-section-{{ section.id }} .kc-sticky__atc {
    height: 46px; padding: 0 22px; border-radius: 99px; border: none;
    color: #FFFFFF; font-family: '{{ section.settings.body_font }}', sans-serif;
    font-size: 14px; font-weight: 800; cursor: pointer;
    white-space: nowrap; flex-shrink: 0;
    transition: opacity 0.2s;
  }
  #shopify-section-{{ section.id }} .kc-sticky__atc:hover { opacity: .88; }
  #shopify-section-{{ section.id }} .kc-sticky__atc:disabled { opacity: .6; cursor: not-allowed; }
  @media (max-width: 899px) {
    #shopify-section-{{ section.id }} .kc-sticky-bar { display: block; }
  }
</style>

<script>
(function() {
  var stickyBtn = document.getElementById('kc-sticky-btn');
  if (!stickyBtn) return;

  function getVid() {
    var vidInput = document.getElementById('kcm-vid');
    return vidInput ? vidInput.value : null;
  }
  function getQty() {
    var qInput = document.getElementById('kcm-qval');
    return qInput ? (parseInt(qInput.value) || 1) : 1;
  }

  stickyBtn.addEventListener('click', function() {
    var vid = getVid();
    var qty = getQty();
    if (!vid) return;
    stickyBtn.disabled = true;
    stickyBtn.textContent = 'Adding\u2026';
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: parseInt(vid, 10), quantity: qty })
    })
    .then(function(r) { return r.json(); })
    .then(function() {
      return fetch('/cart.js');
    })
    .then(function(r) { return r.json(); })
    .then(function(cart) {
      document.querySelectorAll('.cart-count-bubble').forEach(function(el) {
        el.removeAttribute('hidden');
        var sp = el.querySelector('span[aria-hidden]') || el.querySelector('span');
        if (sp) sp.textContent = cart.item_count;
      });
      window.location.href = '/cart';
    })
    .catch(function() {
      stickyBtn.textContent = '{{ section.settings.sticky_button_text }}';
      stickyBtn.disabled = false;
    });
  });
})();
</script>

{% schema %}
{
  "name": "KC — Sticky ATC Bar",
  "settings": [
    { "type": "text", "id": "sticky_button_text", "label": "Button text", "default": "Add to Cart" },
    { "type": "color", "id": "sticky_bg", "label": "Bar background", "default": "#FFFFFF" },
    { "type": "color", "id": "brand_color", "label": "Brand colour", "default": "#6B5FD4" },
    { "type": "color", "id": "muted_color", "label": "Muted colour", "default": "#7A7890" },
    {
      "type": "select", "id": "body_font", "label": "Font",
      "options": [
        { "value": "Nunito", "label": "Nunito" },
        { "value": "Poppins", "label": "Poppins" },
        { "value": "Inter", "label": "Inter" },
        { "value": "DM Sans", "label": "DM Sans" },
        { "value": "Raleway", "label": "Raleway" }
      ],
      "default": "Nunito"
    }
  ],
  "presets": [
    {
      "name": "KC \u2014 Sticky ATC Bar"
    }
  ]
}
{% endschema %}
