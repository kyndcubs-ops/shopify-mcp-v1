<div id="shopify-section-{{ section.id }}" class="kc-ugc">
  <div class="kc-ugc__inner">
    <h2 class="kc-ugc__heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.subheading != blank -%}
      <p class="kc-ugc__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
    <div class="kc-ugc__grid">
      {%- for block in section.blocks -%}
        <div class="kc-ugc__item" {{ block.shopify_attributes }}>
          {%- if block.settings.video_url != blank -%}
            <div class="kc-ugc__video-wrap">
              <iframe src="{{ block.settings.video_url }}" loading="lazy" title="{{ block.settings.name | escape }}" frameborder="0" allowfullscreen></iframe>
            </div>
          {%- elsif block.settings.image != blank -%}
            <div class="kc-ugc__img-wrap">
              <img src="{{ block.settings.image | image_url: width: 480 }}" alt="{{ block.settings.name | escape }}" width="480" height="480" loading="lazy">
            </div>
          {%- else -%}
            <div class="kc-ugc__placeholder"></div>
          {%- endif -%}
          <div class="kc-ugc__overlay">
            <span class="kc-ugc__name">{{ block.settings.name }}</span>
            {%- if block.settings.city != blank -%}
              <span class="kc-ugc__city">{{ block.settings.city }}</span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} .kc-ugc {
    background-color: #FBF8F4;
    padding: 32px 16px;
  }
  #shopify-section-{{ section.id }} .kc-ugc__inner { max-width: 1100px; margin: 0 auto; }
  #shopify-section-{{ section.id }} .kc-ugc__heading {
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 24px;
    color: #2C2A3A;
    text-align: center;
    margin-bottom: 8px;
  }
  #shopify-section-{{ section.id }} .kc-ugc__subheading {
    font-size: 15px;
    color: #7A7890;
    text-align: center;
    font-family: 'Nunito', sans-serif;
    margin-bottom: 24px;
  }
  #shopify-section-{{ section.id }} .kc-ugc__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  #shopify-section-{{ section.id }} .kc-ugc__item {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    aspect-ratio: 1/1;
    background-color: #EDE8E0;
  }
  #shopify-section-{{ section.id }} .kc-ugc__img-wrap,
  #shopify-section-{{ section.id }} .kc-ugc__video-wrap { width: 100%; height: 100%; }
  #shopify-section-{{ section.id }} .kc-ugc__img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }
  #shopify-section-{{ section.id }} .kc-ugc__video-wrap iframe { width: 100%; height: 100%; border: 0; }
  #shopify-section-{{ section.id }} .kc-ugc__placeholder { width: 100%; height: 100%; background-color: #F0EBE3; }
  #shopify-section-{{ section.id }} .kc-ugc__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(44,42,58,0.75) 0%, transparent 100%);
    padding: 20px 12px 12px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  #shopify-section-{{ section.id }} .kc-ugc__name {
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    font-size: 13px;
    color: #FFFFFF;
  }
  #shopify-section-{{ section.id }} .kc-ugc__city {
    font-size: 11px;
    color: rgba(255,255,255,0.8);
    font-family: 'Nunito', sans-serif;
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .kc-ugc { padding: 48px 40px; }
    #shopify-section-{{ section.id }} .kc-ugc__heading { font-size: 32px; }
    #shopify-section-{{ section.id }} .kc-ugc__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }
    #shopify-section-{{ section.id }} .kc-ugc__name { font-size: 14px; }
    #shopify-section-{{ section.id }} .kc-ugc__city { font-size: 12px; }
  }
</style>

{% schema %}
{
  "name": "UGC Gallery",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Loved by real families"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Parents across India are sharing their joy"
    }
  ],
  "blocks": [
    {
      "type": "ugc_item",
      "name": "UGC Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "Video embed URL (optional)"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Customer name",
          "default": "Priya R."
        },
        {
          "type": "text",
          "id": "city",
          "label": "City",
          "default": "Mumbai"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC Gallery",
      "blocks": [
        { "type": "ugc_item", "settings": { "name": "Priya R.", "city": "Mumbai" } },
        { "type": "ugc_item", "settings": { "name": "Ankit S.", "city": "Bangalore" } },
        { "type": "ugc_item", "settings": { "name": "Deepa M.", "city": "Delhi" } },
        { "type": "ugc_item", "settings": { "name": "Rahul P.", "city": "Pune" } }
      ]
    }
  ]
}
{% endschema %}
