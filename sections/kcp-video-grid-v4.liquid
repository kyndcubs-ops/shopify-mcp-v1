{%- liquid
  assign demo_video = product.metafields.custom.demo_video_url
-%}
<div id="shopify-section-{{ section.id }}" class="kcp-video-grid">
  <h2 class="kcp-vg__heading">{{ section.settings.heading }}</h2>
  <div class="kcp-vg__grid">
    {%- if demo_video != blank -%}
      <div class="kcp-vg__card">
        <div class="kcp-vg__video-wrap">
          <iframe src="{{ demo_video }}" loading="lazy" title="Product demo" frameborder="0" allowfullscreen allow="autoplay; encrypted-media"></iframe>
        </div>
        <div class="kcp-vg__card-info">
          <span class="kcp-vg__card-name">{{ section.settings.demo_name }}</span>
          <span class="kcp-vg__card-city">{{ section.settings.demo_city }}</span>
          {%- if section.settings.demo_quote != blank -%}
            <p class="kcp-vg__card-quote">"{{ section.settings.demo_quote }}"</p>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
    {%- for block in section.blocks -%}
      {%- if block.settings.video_url != blank -%}
        <div class="kcp-vg__card" {{ block.shopify_attributes }}>
          <div class="kcp-vg__video-wrap">
            <iframe src="{{ block.settings.video_url }}" loading="lazy" title="{{ block.settings.name | escape }}" frameborder="0" allowfullscreen allow="autoplay; encrypted-media"></iframe>
          </div>
          <div class="kcp-vg__card-info">
            <span class="kcp-vg__card-name">{{ block.settings.name }}</span>
            {%- if block.settings.city != blank -%}
              <span class="kcp-vg__card-city">{{ block.settings.city }}</span>
            {%- endif -%}
            {%- if block.settings.quote != blank -%}
              <p class="kcp-vg__card-quote">"{{ block.settings.quote }}"</p>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} .kcp-video-grid {
    padding: 32px 16px;
    background-color: #FBF8F4;
    font-family: 'Nunito', sans-serif;
  }
  #shopify-section-{{ section.id }} .kcp-vg__heading {
    font-weight: 900;
    font-size: 22px;
    color: #2C2A3A;
    margin-bottom: 20px;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .kcp-vg__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  #shopify-section-{{ section.id }} .kcp-vg__card {
    background-color: #FFFFFF;
    border-radius: 14px;
    border: 1.5px solid #EDE8E0;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .kcp-vg__video-wrap {
    position: relative;
    aspect-ratio: 9/16;
    background-color: #2C2A3A;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .kcp-vg__video-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  #shopify-section-{{ section.id }} .kcp-vg__card-info {
    padding: 10px 12px 12px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  #shopify-section-{{ section.id }} .kcp-vg__card-name {
    font-weight: 800;
    font-size: 13px;
    color: #2C2A3A;
  }
  #shopify-section-{{ section.id }} .kcp-vg__card-city {
    font-size: 11px;
    color: #7A7890;
  }
  #shopify-section-{{ section.id }} .kcp-vg__card-quote {
    font-size: 12px;
    font-style: italic;
    color: #7A7890;
    margin-top: 4px;
    line-height: 1.4;
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .kcp-video-grid { padding: 40px 32px; }
    #shopify-section-{{ section.id }} .kcp-vg__heading { font-size: 26px; }
    #shopify-section-{{ section.id }} .kcp-vg__grid { gap: 20px; }
    #shopify-section-{{ section.id }} .kcp-vg__card-name { font-size: 14px; }
    #shopify-section-{{ section.id }} .kcp-vg__card-city { font-size: 12px; }
    #shopify-section-{{ section.id }} .kcp-vg__card-quote { font-size: 13px; }
  }
  @media (min-width: 900px) {
    #shopify-section-{{ section.id }} .kcp-vg__grid { grid-template-columns: repeat(4, 1fr); }
    #shopify-section-{{ section.id }} .kcp-vg__heading { font-size: 30px; }
  }
</style>

{% schema %}
{
  "name": "Product Videos",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "See it in action"
    },
    {
      "type": "text",
      "id": "demo_name",
      "label": "Main video — customer name",
      "default": "Priya R."
    },
    {
      "type": "text",
      "id": "demo_city",
      "label": "Main video — city",
      "default": "Mumbai"
    },
    {
      "type": "text",
      "id": "demo_quote",
      "label": "Main video — quote",
      "default": "My daughter absolutely loves it!"
    }
  ],
  "blocks": [
    {
      "type": "video_card",
      "name": "Video Card",
      "settings": [
        {
          "type": "text",
          "id": "video_url",
          "label": "Video embed URL",
          "default": "https://www.youtube.com/embed/dQw4w9WgXcQ"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Customer name",
          "default": "Parent"
        },
        {
          "type": "text",
          "id": "city",
          "label": "City",
          "default": "India"
        },
        {
          "type": "text",
          "id": "quote",
          "label": "Quote",
          "default": "Amazing product!"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Videos"
    }
  ]
}
{% endschema %}
