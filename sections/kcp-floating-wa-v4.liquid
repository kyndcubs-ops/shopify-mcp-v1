{%- liquid
  assign wa_num = section.settings.wa_number
  assign wa_msg = 'Hi! I have a question about ' | append: product.title
  assign wa_link = 'https://wa.me/' | append: wa_num | append: '?text=' | append: wa_msg | url_encode
-%}
<div id="shopify-section-{{ section.id }}" class="kcp-floating-wa">
  <a href="{{ wa_link }}" target="_blank" rel="noopener" class="kcp-fwa__btn" aria-label="Chat on WhatsApp">
    <svg width="26" height="26" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M13 1C6.373 1 1 6.373 1 13c0 2.098.525 4.073 1.447 5.8L1 25l6.362-1.43A11.934 11.934 0 0013 25c6.627 0 12-5.373 12-12S19.627 1 13 1z" fill="#FFFFFF"/>
      <path d="M18.6 16.4c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.95 1.17-.18.2-.35.22-.65.07-.3-.15-1.27-.47-2.42-1.5-.89-.8-1.5-1.78-1.67-2.08-.18-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51-.17 0-.37-.02-.57-.02-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.47s1.07 2.87 1.22 3.07c.15.2 2.1 3.2 5.08 4.49.71.31 1.26.49 1.69.63.71.22 1.36.19 1.87.12.57-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z" fill="#25D366"/>
    </svg>
  </a>
</div>

<style>
  #shopify-section-{{ section.id }} .kcp-floating-wa {
    position: fixed;
    bottom: 70px;
    right: 16px;
    z-index: 950;
  }
  #shopify-section-{{ section.id }} .kcp-fwa__btn {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background-color: #25D366;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(37,211,102,0.4);
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
  }
  #shopify-section-{{ section.id }} .kcp-fwa__btn:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 20px rgba(37,211,102,0.5);
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .kcp-floating-wa {
      bottom: 24px;
      right: 24px;
    }
  }
</style>

{% schema %}
{
  "name": "Floating WhatsApp",
  "settings": [
    {
      "type": "text",
      "id": "wa_number",
      "label": "WhatsApp number",
      "default": "917509802310"
    }
  ],
  "presets": [
    {
      "name": "Floating WhatsApp"
    }
  ]
}
{% endschema %}
