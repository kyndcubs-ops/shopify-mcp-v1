{%- liquid
  assign why_meta = product.metafields.custom.why_we_chose_this
  assign tab2_material = product.metafields.custom.material
  assign tab2_dims = product.metafields.custom.dimensions
  assign tab2_safety_std = product.metafields.custom.safety_standards
  assign tab2_safety_info = product.metafields.custom.safety_info
  assign tab2_care = product.metafields.custom.care_instructions
  assign tab2_inbox = product.metafields.custom.whats_in_box
  assign tab2_brand = product.vendor
  assign tab2_age = product.metafields.custom.age_range
-%}
<div id="shopify-section-{{ section.id }}" class="kc-tabs">
  <div class="kc-tabs__inner">
    <div class="kc-tabs__nav" role="tablist">
      <button class="kc-tabs__tab kc-tabs__tab--active" role="tab" aria-selected="true" data-tab="why" type="button">{{ section.settings.tab1_label }}</button>
      <button class="kc-tabs__tab" role="tab" aria-selected="false" data-tab="details" type="button">{{ section.settings.tab2_label }}</button>
    </div>

    <div class="kc-tabs__panel kc-tabs__panel--active" id="kc-tab-why-{{ section.id }}" role="tabpanel">
      <ul class="kc-tabs__bullets">
        {%- if why_meta != blank -%}
          {%- assign why_lines = why_meta | split: "\n" -%}
          {%- for line in why_lines -%}
            {%- if line != blank -%}
              <li class="kc-tabs__bullet"><span class="kc-tabs__bullet-icon">{{ section.settings.bullet_icon }}</span><span>{{ line | strip }}</span></li>
            {%- endif -%}
          {%- endfor -%}
        {%- elsif section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'why_bullet' -%}
              <li class="kc-tabs__bullet" {{ block.shopify_attributes }}><span class="kc-tabs__bullet-icon">{{ block.settings.icon | default: section.settings.bullet_icon }}</span><span>{{ block.settings.text }}</span></li>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          <li class="kc-tabs__bullet"><span class="kc-tabs__bullet-icon">{{ section.settings.bullet_icon }}</span><span>Personally tested by our team before listing</span></li>
          <li class="kc-tabs__bullet"><span class="kc-tabs__bullet-icon">{{ section.settings.bullet_icon }}</span><span>Meets EN71 international toy safety standards</span></li>
          <li class="kc-tabs__bullet"><span class="kc-tabs__bullet-icon">{{ section.settings.bullet_icon }}</span><span>Non-toxic and BPA-free throughout</span></li>
          <li class="kc-tabs__bullet"><span class="kc-tabs__bullet-icon">{{ section.settings.bullet_icon }}</span><span>Holds a child's attention for 10+ days</span></li>
        {%- endif -%}
      </ul>
    </div>

    <div class="kc-tabs__panel" id="kc-tab-details-{{ section.id }}" role="tabpanel" hidden>
      <dl class="kc-tabs__detail-list">
        {%- if tab2_brand != blank -%}
          <div class="kc-tabs__detail-row">
            <dt>Brand</dt>
            <dd>{{ tab2_brand }}</dd>
          </div>
        {%- endif -%}
        {%- if tab2_age != blank -%}
          <div class="kc-tabs__detail-row">
            <dt>Age range</dt>
            <dd>{{ tab2_age }}</dd>
          </div>
        {%- endif -%}
        {%- if tab2_material != blank -%}
          <div class="kc-tabs__detail-row">
            <dt>Material</dt>
            <dd>{{ tab2_material }}</dd>
          </div>
        {%- endif -%}
        {%- if tab2_dims != blank -%}
          <div class="kc-tabs__detail-row">
            <dt>Dimensions</dt>
            <dd>{{ tab2_dims }}</dd>
          </div>
        {%- endif -%}
        {%- if tab2_safety_std != blank -%}
          <div class="kc-tabs__detail-row">
            <dt>Safety standards</dt>
            <dd>{{ tab2_safety_std }}</dd>
          </div>
        {%- endif -%}
        {%- if tab2_safety_info != blank -%}
          <div class="kc-tabs__detail-row">
            <dt>Safety info</dt>
            <dd>{{ tab2_safety_info }}</dd>
          </div>
        {%- endif -%}
        {%- if tab2_care != blank -%}
          <div class="kc-tabs__detail-row">
            <dt>Care instructions</dt>
            <dd>{{ tab2_care }}</dd>
          </div>
        {%- endif -%}
        {%- if tab2_inbox != blank -%}
          <div class="kc-tabs__detail-row">
            <dt>What's in the box</dt>
            <dd>{{ tab2_inbox }}</dd>
          </div>
        {%- endif -%}
        {%- if tab2_brand == blank and tab2_age == blank and tab2_material == blank and tab2_dims == blank -%}
          <div class="kc-tabs__detail-row">
            <dt>Brand</dt>
            <dd>Kynd Cubs</dd>
          </div>
          <div class="kc-tabs__detail-row">
            <dt>Safety</dt>
            <dd>EN71 certified, non-toxic, BPA-free</dd>
          </div>
        {%- endif -%}
      </dl>
    </div>
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} .kc-tabs {
    padding: 28px 16px;
    font-family: '{{ section.settings.body_font }}', sans-serif;
    background: #FFFFFF;
  }
  #shopify-section-{{ section.id }} .kc-tabs__inner { max-width: 900px; margin: 0 auto; }
  #shopify-section-{{ section.id }} .kc-tabs__nav {
    display: flex; gap: 8px; margin-bottom: 20px;
    background: {{ section.settings.brand_color_lt }};
    border-radius: 99px; padding: 4px;
  }
  #shopify-section-{{ section.id }} .kc-tabs__tab {
    flex: 1; padding: 9px 16px; border-radius: 99px; border: none;
    background: none; font-family: '{{ section.settings.body_font }}', sans-serif;
    font-size: 13px; font-weight: 800; color: {{ section.settings.muted_color }};
    cursor: pointer; transition: background 0.2s, color 0.2s; text-align: center;
  }
  #shopify-section-{{ section.id }} .kc-tabs__tab--active {
    background: {{ section.settings.brand_color }};
    color: #FFFFFF;
  }
  #shopify-section-{{ section.id }} .kc-tabs__panel { display: none; }
  #shopify-section-{{ section.id }} .kc-tabs__panel--active { display: block; }
  #shopify-section-{{ section.id }} .kc-tabs__bullets { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 12px; }
  #shopify-section-{{ section.id }} .kc-tabs__bullet {
    display: flex; align-items: flex-start; gap: 10px;
    font-size: 14px; font-weight: 700; color: {{ section.settings.text_color }};
    line-height: 1.5;
  }
  #shopify-section-{{ section.id }} .kc-tabs__bullet-icon { font-size: 16px; flex-shrink: 0; margin-top: 1px; }
  #shopify-section-{{ section.id }} .kc-tabs__detail-list { margin: 0; padding: 0; }
  #shopify-section-{{ section.id }} .kc-tabs__detail-row {
    display: flex; gap: 12px; padding: 10px 0;
    border-bottom: 1px solid #F0EDFF;
    font-size: 14px;
  }
  #shopify-section-{{ section.id }} .kc-tabs__detail-row dt {
    font-weight: 800; color: {{ section.settings.muted_color }};
    min-width: 130px; flex-shrink: 0;
  }
  #shopify-section-{{ section.id }} .kc-tabs__detail-row dd {
    color: {{ section.settings.text_color }};
    font-weight: 700; margin: 0;
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .kc-tabs { padding: 32px; }
  }
</style>

<script>
(function() {
  var section = document.getElementById('shopify-section-{{ section.id }}');
  if (!section) return;
  var tabs = section.querySelectorAll('.kc-tabs__tab');
  var panels = section.querySelectorAll('.kc-tabs__panel');
  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      tabs.forEach(function(t) { t.classList.remove('kc-tabs__tab--active'); t.setAttribute('aria-selected', 'false'); });
      panels.forEach(function(p) { p.classList.remove('kc-tabs__panel--active'); p.setAttribute('hidden', ''); });
      tab.classList.add('kc-tabs__tab--active');
      tab.setAttribute('aria-selected', 'true');
      var panelId = 'kc-tab-' + tab.getAttribute('data-tab') + '-{{ section.id }}';
      var panel = document.getElementById(panelId);
      if (panel) { panel.classList.add('kc-tabs__panel--active'); panel.removeAttribute('hidden'); }
    });
  });
})();
</script>

{% schema %}
{
  "name": "KC — Product Tabs",
  "settings": [
    { "type": "text", "id": "tab1_label", "label": "Tab 1 label", "default": "Why we chose this" },
    { "type": "text", "id": "tab2_label", "label": "Tab 2 label", "default": "Product details" },
    { "type": "text", "id": "bullet_icon", "label": "Bullet icon", "default": "✅" },
    { "type": "color", "id": "brand_color", "label": "Brand colour", "default": "#6B5FD4" },
    { "type": "color", "id": "brand_color_lt", "label": "Brand light", "default": "#F0EDFF" },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#2C2A3A" },
    { "type": "color", "id": "muted_color", "label": "Muted colour", "default": "#7A7890" },
    { "type": "range", "id": "border_radius", "label": "Radius", "min": 0, "max": 24, "step": 1, "unit": "px", "default": 12 },
    {
      "type": "select", "id": "body_font", "label": "Font",
      "options": [
        { "value": "Nunito", "label": "Nunito" },
        { "value": "Poppins", "label": "Poppins" },
        { "value": "Inter", "label": "Inter" },
        { "value": "DM Sans", "label": "DM Sans" },
        { "value": "Raleway", "label": "Raleway" }
      ],
      "default": "Nunito"
    }
  ],
  "blocks": [
    {
      "type": "why_bullet",
      "name": "Why Bullet",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (optional, overrides default)" },
        { "type": "text", "id": "text", "label": "Bullet text", "default": "A reason parents love this" }
      ]
    }
  ],
  "presets": [
    {
      "name": "KC \u2014 Product Tabs"
    }
  ]
}
{% endschema %}
